<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Inherit base view for standard fields -->
    <record id="view_employee_form_inherit_custom_base" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.custom.base</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <field name="department_id" position="attributes">
                <attribute name="required">1</attribute>
            </field>
            <field name="job_id" position="attributes">
                <attribute name="required">1</attribute>
            </field>
            <xpath expr="//field[@name='employee_code']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Inherit hr_employee_entended view for father_name -->
    <record id="view_employee_form_inherit_custom_extended" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.custom.extended</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr_employee_entended.view_employee_form_adding_imp_fields"/>
        <field name="arch" type="xml">
            <field name="father_name" position="attributes">
                <attribute name="required">1</attribute>
            </field>
        </field>
    </record>
</odoo>
